{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "1. 启动前台 H5（dev 热更新）",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "2. 启动管理后台（dev 热更新）",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}/admin"
    },
    {
      "name": "3. 启动前台 API",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/go_server",
      "cwd": "${workspaceFolder}/go_server",
      "env": {
        "GO_SERVER_ADDR": ":18080",
        "GO_SERVER_DSN": "root:123456@tcp(127.0.0.1:3306)/football_data?charset=utf8mb4&parseTime=True&loc=Local",
        "FOOTBALL_IMG_DIR": "${workspaceFolder}/public/footballimg"
      }
    },
    {
      "name": "4. 启动管理 API",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/go_admin",
      "cwd": "${workspaceFolder}/go_admin",
      "env": {
        "ADMIN_SERVER_ADDR": ":8081",
        "DB_HOST": "127.0.0.1",
        "DB_PORT": "3306",
        "DB_USER": "root",
        "DB_PASSWORD": "123456",
        "DB_NAME": "football_data",
        "FOOTBALL_IMG_DIR": "${workspaceFolder}/public/footballimg"
      }
    }
  ],
  "compounds": [
    {
      "name": "5. 启动全部",
      "configurations": [
        "1. 启动前台 H5（dev 热更新）",
        "2. 启动管理后台（dev 热更新）",
        "3. 启动前台 API",
        "4. 启动管理 API"
      ],
      "stopAll": false
    }
  ]
}
